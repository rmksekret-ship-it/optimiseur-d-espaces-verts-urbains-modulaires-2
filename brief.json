    "document_html": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Optimiseur d&#x27;Espaces Verts Urbains Modulaires | Imaginez, Concevez, Réalisez : Votre Espace Vert Urbain sur Mesure</title>\n    <meta name=\"description\" content=\"Planifiez des jardins communautaires ou personnels en choisissant des modules pré-conçus (potagers, zones de repos, etc.) et en visualisant l\">\n    <style>\n        body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen-Sans, Ubuntu, Cantarell, \"Helvetica Neue\", sans-serif; background-color: #1a1a1a; color: #e0e0e0; display: flex; flex-direction: column; min-height: 100vh; font-size: 16px; line-height: 1.6; }\n        .container { width: 90%; max-width: 1200px; margin: 0 auto; padding: 20px 0; }\n        header { background-color: #2a2a2a; padding: 20px 0; border-bottom: 1px solid #3a3a3a; }\n        header h1 { margin: 0; color: #00ffcc; text-align: center; font-size: 2.5em; font-weight: 600; }\n        .hero { display: flex; flex-direction: column; align-items: center; text-align: center; padding: 60px 0; background-color: #1a1a1a; border-bottom: 1px solid #3a3a3a; }\n        .hero h2 { color: #00ccff; font-size: 2em; margin-bottom: 20px; }\n        .hero p { max-width: 800px; font-size: 1.1em; color: #b0b0b0; }\n        .main-content { display: grid; grid-template-columns: 1fr 2fr; gap: 40px; padding: 40px 0; }\n        .sidebar { background-color: #2a2a2a; padding: 30px; border-radius: 8px; border: 1px solid #3a3a3a; box-shadow: 0 4px 10px rgba(0,0,0,0.3); }\n        .tool-area { background-color: #1a1a1a; padding: 30px; border-radius: 8px; border: 1px solid #3a3a3a; box-shadow: 0 4px 10px rgba(0,0,0,0.3); }\n        h3 { color: #00ffcc; margin-top: 0; font-size: 1.5em; }\n        form label { display: block; margin-bottom: 8px; color: #00ccff; font-weight: bold; }\n        form select, form input[type=\"number\"] { width: calc(100% - 20px); padding: 10px; margin-bottom: 20px; background-color: #3a3a3a; border: 1px solid #5a5a5a; color: #e0e0e0; border-radius: 4px; }\n        form button { background-color: #00ffcc; color: #1a1a1a; padding: 12px 25px; border: none; border-radius: 4px; cursor: pointer; font-size: 1.1em; font-weight: bold; transition: background-color 0.3s ease; }\n        form button:hover { background-color: #00e6b8; }\n        .result-area { margin-top: 30px; padding-top: 20px; border-top: 1px solid #3a3a3a; }\n        .result-area h4 { color: #00ccff; font-size: 1.3em; margin-bottom: 15px; }\n        .result-area pre { background-color: #3a3a3a; padding: 15px; border-radius: 4px; overflow-x: auto; color: #e0e0e0; font-family: monospace; border: 1px solid #5a5a5a; }\n        .bento-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 40px; }\n        .bento-item { background-color: #2a2a2a; padding: 25px; border-radius: 8px; border: 1px solid #3a3a3a; box-shadow: 0 2px 5px rgba(0,0,0,0.2); text-align: center; }\n        .bento-item h4 { color: #00ffcc; font-size: 1.2em; margin-bottom: 10px; }\n        .bento-item p { color: #b0b0b0; font-size: 0.95em; }\n        .seo-section { background-color: #222222; padding: 40px 0; border-top: 1px solid #3a3a3a; color: #b0b0b0; text-align: center; font-size: 0.9em; }\n        .seo-section h3 { color: #00ccff; font-size: 1.8em; margin-bottom: 20px; }\n        .seo-section p { max-width: 900px; margin: 0 auto 15px auto; }\n        .seo-section ul { list-style: none; padding: 0; display: inline-block; text-align: left; margin-top: 20px; }\n        .seo-section li { margin-bottom: 8px; color: #888; }\n        .seo-section li strong { color: #00ffcc; }\n        footer { background-color: #1a1a1a; color: #888; text-align: center; padding: 20px 0; border-top: 1px solid #3a3a3a; font-size: 0.9em; }\n\n        @media (max-width: 768px) {\n            .main-content { grid-template-columns: 1fr; }\n            .hero h1 { font-size: 2em; }\n            .hero h2 { font-size: 1.5em; }\n            header h1 { font-size: 2em; }\n        }\n    </style>\n    <meta name=\"robots\" content=\"index, follow\">\n    <link rel=\"canonical\" href=\"https://optimiseur-d-espaces-verts-urbains-modulaires-2.onrender.com\">\n    <meta property=\"og:title\" content=\"Optimiseur d&#x27;Espaces Verts Urbains Modulaires\">\n    <meta property=\"og:description\" content=\"Planifiez des jardins communautaires ou personnels en choisissant des modules pré-conçus (potagers, zones de repos, etc.) et en visualisant l\">\n    <meta property=\"og:url\" content=\"https://optimiseur-d-espaces-verts-urbains-modulaires-2.onrender.com\">\n    <meta property=\"og:type\" content=\"website\">\n    <script type=\"application/ld+json\">{\"@context\": \"https://schema.org\", \"@type\": \"WebApplication\", \"name\": \"Optimiseur d'Espaces Verts Urbains Modulaires\", \"description\": \"Planifiez des jardins communautaires ou personnels en choisissant des modules pré-conçus (potagers, zones de repos, etc.) et en visualisant l\", \"url\": \"https://optimiseur-d-espaces-verts-urbains-modulaires-2.onrender.com\", \"applicationCategory\": \"UtilityApplication\", \"operatingSystem\": \"Web Browser\"}</script>\n</head>\n<body data-site-slug=\"optimiseur-d-espaces-verts-urbains-modulaires-2\" data-runtime-mode=\"analysis_tool\">\n    <header>\n        <div class=\"container\">\n            <h1>Optimiseur d'Espaces Verts Urbains Modulaires</h1>\n        </div>\n    </header>\n\n    <section class=\"hero\">\n        <div class=\"container\">\n            <h2>Imaginez, Concevez, Réalisez : Votre Espace Vert Urbain sur Mesure</h2>\n            <p>Planifiez facilement des jardins communautaires ou personnels, des micro-fermes urbaines aux zones de détente, en assemblant des modules pré-conçus. Visualisez votre projet avant de le concrétiser.</p>\n        </div>\n    </section>\n\n    <section class=\"container main-content\">\n        <div class=\"sidebar\">\n            <h3>Commencez votre projet</h3>\n            <p>Définissez les paramètres de votre espace. L'alliance de la nature et de la technologie au service de votre vision.</p>\n            <form id=\"tool-form\">\n                <label for=\"type_espace\">Type d'espace :</label>\n                <select id=\"type_espace\" name=\"type_espace\" required>\n                    <option value=\"communautaire\">Jardin Communautaire</option>\n                    <option value=\"personnel\">Jardin Personnel</option>\n                    <option value=\"entreprise\">Espace Vert d'Entreprise</option>\n                    <option value=\"public\">Aménagement Public</option>\n                </select>\n\n                <label for=\"taille_surface\">Taille de la surface (m²) :</label>\n                <input type=\"number\" id=\"taille_surface\" name=\"taille_surface\" min=\"10\" max=\"1000\" value=\"50\" required>\n\n                <label for=\"modules_inclure\">Modules principaux à inclure :</label>\n                <select id=\"modules_inclure\" name=\"modules_inclure\" multiple required style=\"min-height: 120px;\">\n                    <option value=\"potager_intensif\">Potager Intensif</option>\n                    <option value=\"zone_repos\">Zone de Repos & Lecture</option>\n                    <option value=\"fleurs_ornementales\">Jardin de Fleurs Ornementales</option>\n                    <option value=\"aire_jeux_enfants\">Aire de Jeux pour Enfants</option>\n                    <option value=\"point_eau\">Point d'Eau / Bassin</option>\n                    <option value=\"compost_partage\">Compost Partagé</option>\n                    <option value=\"arbres_fruitiers\">Mini-Verger</option>\n                </select>\n\n                <button type=\"submit\" id=\"tool-submit\">Générer ma proposition</button>\n            </form>\n        </div>\n\n        <div class=\"tool-area\">\n            <h3>Votre visualisation 'Bento Signal'</h3>\n            <p>Une proposition d'agencement clair et optimisé. Chaque module s'intègre harmonieusement pour maximiser l'efficacité et l'esthétique de votre espace.</p>\n            <div id=\"tool-result\" class=\"result-area\">\n                <h4>Aperçu de votre Agencement :</h4>\n                <pre id=\"agencement-result\">Votre proposition d'aménagement apparaîtra ici après avoir cliqué sur \"Générer ma proposition\".</pre>\n                <div class=\"bento-grid\" id=\"bento-visualisation\">\n                    <!-- Bento items will be generated here -->\n                </div>\n            </div>\n            <button data-affiliate-slot=\"contact-expert\" style=\"background-color: #00ccff; margin-top: 30px;\">Besoin d'un accompagnement personnalisé ?</button>\n        </div>\n    </section>\n\n    <section class=\"container bento-grid\">\n        <div class=\"bento-item\">\n            <h4>Modularité Avancée</h4>\n            <p>Choisissez parmi une bibliothèque de modules pour construire un jardin unique, adapté à vos besoins spécifiques.</p>\n        </div>\n        <div class=\"bento-item\">\n            <h4>Optimisation Spatiale</h4>\n            <p>Notre algorithme suggère l'agencement le plus fonctionnel pour tirer le meilleur parti de chaque mètre carré.</p>\n        </div>\n        <div class=\"bento-item\">\n            <h4>Esthétique & Durabilité</h4>\n            <p>Des designs modernes et respectueux de l'environnement, pensés pour la beauté et la résilience urbaine.</p>\n        </div>\n        <div class=\"bento-item\">\n            <h4>Pour Tous les Projets</h4>\n            <p>Que vous soyez un particulier, une association ou un urbaniste, trouvez la solution qui vous correspond.</p>\n        </div>\n    </section>\n\n    <section class=\"seo-section\">\n        <div class=\"container\">\n            <h3>Découvrez le futur du jardinage urbain en France</h3>\n            <p>Notre plateforme est le <strong style=\"color: #00ffcc;\">leader français</strong> pour la conception d'espaces verts modulaires. Que vous recherchiez un <strong style=\"color: #00ccff;\">logiciel aménagement jardin gratuit</strong>, des <strong style=\"color: #00ffcc;\">idées jardin urbain</strong> ou un <strong style=\"color: #00ccff;\">plan potager communautaire</strong>, notre outil vous offre une solution innovante. Visualisez votre <strong style=\"color: #00ffcc;\">jardin partagé</strong>, optimisez votre <strong style=\"color: #00ccff;\">balcon potager</strong> ou concevez un <strong style=\"color: #00ffcc;\">espace vert d'entreprise</strong> avec facilité. Fini les approximations, place à la précision et à l'esthétique \"Mechanical Botanical\".</p>\n            <p>Rejoignez les <strong style=\"color: #00ffcc;\">citadins écologiques</strong>, les <strong style=\"color: #00ccff;\">associations de quartier</strong> et les <strong style=\"color: #00ffcc;\">municipalités</strong> qui transforment nos villes. Trouvez des solutions pour l'aménagement paysager, des conseils pour un <strong style=\"color: #00ccff;\">jardin résilient</strong> et des <strong style=\"color: #00ffcc;\">plans d'aménagement extérieur</strong> adaptés à la réalité urbaine française. Notre outil est votre allié pour un <strong style=\"color: #00ccff;\">développement durable en ville</strong> et la création d'îlots de fraîcheur verdoyants.</p>\n        </div>\n    </section>\n\n    <footer>\n        <div class=\"container\">\n            <p>&copy; 2023 Optimiseur d'Espaces Verts Urbains Modulaires. Tous droits réservés.</p>\n        </div>\n    </footer>\n\n    <script>\n        document.getElementById('tool-form').addEventListener('submit', function(event) {\n            event.preventDefault();\n\n            const typeEspace = document.getElementById('type_espace').value;\n            const tailleSurface = document.getElementById('taille_surface').value;\n            const modulesSelectionnes = Array.from(document.getElementById('modules_inclure').selectedOptions).map(option => option.value);\n\n            let agencementText = `Projet : ${typeEspace.charAt(0).toUpperCase() + typeEspace.slice(1)}\\n`;\n            agencementText += `Surface : ${tailleSurface} m²\\n\\n`;\n            agencementText += `Modules proposés :\\n`;\n\n            const descriptionsModules = {\n                potager_intensif: \"Un module pour la production de légumes et herbes aromatiques en haute densité.\",\n                zone_repos: \"Un espace de détente avec bancs, ombrage et éventuellement une petite fontaine.\",\n                fleurs_ornementales: \"Un jardin fleuri pour la biodiversité et l'esthétique, attractif pour les pollinisateurs.\",\n                aire_jeux_enfants: \"Un petit espace sécurisé avec des jeux pour les enfants (selon taille de la surface).\",\n                point_eau: \"Un élément aquatique pour la fraîcheur, la biodiversité et l'ambiance sonore.\",\n                compost_partage: \"Zone dédiée au compostage collectif, essentielle pour le cycle des nutriments.\",\n                arbres_fruitiers: \"Quelques arbres fruitiers nains ou en espalier pour une récolte locale.\"\n            };\n\n            const bentoContainer = document.getElementById('bento-visualisation');\n            bentoContainer.innerHTML = ''; // Clear previous visualizations\n\n            if (modulesSelectionnes.length === 0) {\n                agencementText += \"Aucun module principal sélectionné. Veuillez en choisir au moins un.\\n\";\n            } else {\n                modulesSelectionnes.forEach(module => {\n                    agencementText += `- ${module.replace(/_/g, ' ').toUpperCase()}: ${descriptionsModules[module]}\\n`;\n\n                    const bentoItem = document.createElement('div');\n                    bentoItem.classList.add('bento-item');\n                    const title = document.createElement('h4');\n            